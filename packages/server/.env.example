# Required everywhere — the server refuses to boot without these.
DATABASE_URL=postgres://localhost:5432/sidekick
OPENAI_API_KEY=              # chat model, voice-note transcription, web search

# Required additionally when NODE_ENV=production.
# CRON_SECRET=               # bearer for /cron/*; also what the in-process scheduler sends
# PUBLIC_API_URL=            # public base URL for attachment links (prod: https://api.sidekickchat.app)

# Runtime
# NODE_ENV=development       # development | test | production
# PORT=8787                  # Railway injects this
# LOG_LEVEL=                 # silent|fatal|error|warn|info|debug|trace (default: debug, info in prod)
# CORS_ALLOWED_ORIGINS=      # comma-separated exact origins; unset = any origin

# Error reporting — sans-software/sidekick-server. Unset disables Sentry entirely.
# SENTRY_DSN=https://21ca8435f84c985bd0f77e81db72ded5@o4506271568166912.ingest.us.sentry.io/4511769127485440

# Optional — features degrade gracefully when unset
# SIDEKICK_DISABLED_TOOLS=   # comma-separated tool names to withhold
# SIDEKICK_AD_IAB_CLASSIFY=  # 1 runs the model classification pass in the ad-profile sweep
# BLOB_READ_WRITE_TOKEN=     # Vercel Blob; unset = local disk store
# LOCAL_BLOB_DIR=            # local store dir (default .blob-store)
# GRAVITY_API_KEY=           # ads (unset = ads disabled)
# GRAVITY_API_URL=
# GRAVITY_PRODUCTION=false   # true enables paid inventory; false uses test ads
# WEATHER_API_KEY=           # OpenWeatherMap for check-in openers
# EXPO_ACCESS_TOKEN=         # Expo push for check-ins/reminders

# Apple Music — all three or none.
# MUSIC_TOKEN_KEY=           # base64 32-byte AES key for Apple Music user tokens
# APPLE_MUSIC_PRIVATE_KEY=
# APPLE_MUSIC_KEY_ID=
# APPLE_MUSIC_TEAM_ID=

# Apple sign-in
APP_BUNDLE_IDENTIFIER=        # iOS audience (from app.config.js bundle id)
APPLE_SERVICES_ID=            # web audience (unused until Apple-on-web)

# Google sign-in
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# Email OTP (unset in dev → codes logged to console; both or neither)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SMS OTP (Twilio Verify) — all three or none.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
