# Required
DATABASE_URL=postgres://localhost:5432/sidekick
ANTHROPIC_API_KEY=

# Model overrides
# SIDEKICK_CHAT_MODEL=claude-sonnet-4-5
# SIDEKICK_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Optional — features degrade gracefully when unset
# OPENAI_API_KEY=            # voice-note transcription
# SIDEKICK_DISABLED_TOOLS=   # comma-separated tool names to withhold
# CRON_SECRET=               # bearer for /cron/* endpoints
# PUBLIC_API_URL=            # public base URL for attachment links (default http://localhost:8787)
# BLOB_READ_WRITE_TOKEN=     # Vercel Blob; unset = local disk store
# LOCAL_BLOB_DIR=            # local store dir (default .blob-store)
# GRAVITY_API_KEY=           # ads (unset = ads disabled)
# GRAVITY_API_URL=
# GRAVITY_PRODUCTION=false   # true enables paid inventory; false uses test ads
# WEATHER_API_KEY=           # OpenWeatherMap for check-in openers
# EXPO_ACCESS_TOKEN=         # Expo push for check-ins/reminders
# MUSIC_TOKEN_KEY=           # base64 32-byte AES key for Apple Music user tokens
# APPLE_MUSIC_PRIVATE_KEY=
# APPLE_MUSIC_KEY_ID=
# APPLE_MUSIC_TEAM_ID=
# PORT=8787
