# Base URL of @sidekick/server (pnpm dev:server runs it on 8787).
# Use your machine's LAN IP instead of localhost when testing on a device.
EXPO_PUBLIC_API_URL=http://localhost:8787

# Google sign-in OAuth client ids (Google Cloud console). Leave unset in dev —
# the Google button disables itself; use "Dev login" instead.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# PostHog project API key (PostHog → Settings → Project). Leave unset in dev —
# analytics runs disabled and sends nothing.
EXPO_PUBLIC_POSTHOG_API_KEY=

# Sentry DSN for the sans-software/sidekick-expo project. Leave unset in dev —
# the SDK initialises disabled and sends nothing.
EXPO_PUBLIC_SENTRY_DSN=

# Meta ads attribution (Meta app dashboard). Both are required together; with
# either unset the Facebook SDK and its tracking prompt are left out of the
# build entirely. Only needed once you're running Meta ad campaigns.
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=

# Set to 1 to drop the Screen Time (react-native-device-activity) plugin, which
# needs the family-controls entitlement. Required for simulator builds.
# EXPO_PUBLIC_DISABLE_DEVICE_ACTIVITY=1

# Set to 1 to replace the 3D scene with a static backdrop. expo-gl on the
# simulator is a software renderer, so the scene is slow there and a GL crash
# takes the app down — turn it off when you're working on chat/shop/map.
# Requires a Metro restart (EXPO_PUBLIC_* is inlined at bundle time).
# EXPO_PUBLIC_DISABLE_3D=1
