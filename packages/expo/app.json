{
  "expo": {
    "name": "sidekick-mobile",
    "slug": "sidekick-mobile",
    "owner": "cjenr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sidekickmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanssoftware.sidekick",
      "appleTeamId": "DNCJ9P24DP",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Sidekick reads your steps, sleep, and workouts so it can cheer you on without you having to report anything. It only reads — never writes or shares.",
        "NSLocationWhenInUseUsageDescription": "Sidekick uses your city — only while you're using the app — to know your weather and what's nearby.",
        "NSLocalNetworkUsageDescription": "Sidekick connects to your local development server while you test the app on this iPhone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      "expo-secure-store",
      "expo-web-browser",
      "expo-location",
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "microphonePermission": "Sidekick uses the microphone so you can send voice notes in chat."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "background": true
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "DNCJ9P24DP",
          "appGroup": "group.com.sanssoftware.sidekick"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.sanssoftware.sidekick.ShieldConfiguration",
                  "targetName": "ShieldConfiguration",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.sanssoftware.sidekick"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.sanssoftware.sidekick.ShieldAction",
                  "targetName": "ShieldAction",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.sanssoftware.sidekick"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.sanssoftware.sidekick.ActivityMonitorExtension",
                  "targetName": "ActivityMonitorExtension",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.sanssoftware.sidekick"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "a7d12cd6-d264-465b-9199-fbaacd985bcd"
      }
    }
  }
}
