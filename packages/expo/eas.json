{
  "cli": {
    "version": ">= 16.6.1",
    "promptToConfigurePushNotifications": false,
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.11.0",
      "pnpm": "10.34.1"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "simulator": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_DISABLE_DEVICE_ACTIVITY": "1"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.sidekickchat.app"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.sidekickchat.app",
        // Screen Time needs com.apple.developer.family-controls, whose
        // Distribution variant requires manual Apple approval. Until that
        // request is granted, App Store profiles can't carry the capability and
        // the archive fails signing on all four targets. Remove this line the
        // day approval lands — nothing else needs to change.
        "EXPO_PUBLIC_DISABLE_DEVICE_ACTIVITY": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6792917447"
      }
    }
  }
}
