{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "Sidekick Node",
	"extends": "./base.json",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"types": ["node"]
	}
}
