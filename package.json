{
	"name": "sidekick",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.34.1",
	"scripts": {
		"dev": "pnpm --filter @sidekick/web dev",
		"dev:web": "pnpm --filter @sidekick/web dev",
		"dev:expo": "pnpm --filter @sidekick/expo start",
		"build": "pnpm --filter @sidekick/web build",
		"typecheck": "pnpm -r run typecheck"
	},
	"pnpm": {
		"overrides": {
			"three": "0.185.1",
			"@types/three": "0.185.0"
		},
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"unrs-resolver"
		]
	}
}
