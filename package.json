{
	"name": "sidekick",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.34.1",
	"scripts": {
		"dev": "pnpm --filter @sidekick/expo web",
		"dev:web": "pnpm --filter @sidekick/expo web",
		"dev:expo": "pnpm --filter @sidekick/expo start",
		"dev:vite": "pnpm --filter @sidekick/web dev",
		"dev:server": "pnpm --filter @sidekick/server dev",
		"build": "pnpm --filter @sidekick/web build",
		"typecheck": "pnpm -r run typecheck && tsc -p tests",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "pnpm --filter @sidekick/db generate",
		"db:migrate": "pnpm --filter @sidekick/db migrate"
	},
	"devDependencies": {
		"@sidekick/db": "workspace:*",
		"@sidekick/server": "workspace:*",
		"@sidekick/shared": "workspace:*",
		"@sidekick/tsconfig": "workspace:*",
		"@types/node": "^22.20.0",
		"msw": "^2.7.0",
		"typescript": "^5.7.2",
		"vitest": "^3.0.5"
	},
	"pnpm": {
		"overrides": {
			"three": "0.185.1",
			"@types/three": "0.185.0"
		},
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"unrs-resolver"
		]
	}
}
