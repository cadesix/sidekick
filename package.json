{
  "name": "sidekick-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "web"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run generate --workspace @sidekick/db"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "msw": "^2.7.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
